######## LIBRARY                                                                                                                       ########
######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ########
library("tidyverse") # for data manipulation & plots
library("lubridate") # right color
library("BUSpaRse")
library("TENxBUSData")
library("simpleSingleCell") # for scRNA storage & manipulation
library("scater") # for QC control
library("scran") # analysis pipeline
library("Seurat")
library("uwot") # UMAP dim-red
library("DropletUtils") #utility functions for handling single-cell (RNA-seq)
library("AnnotationHub") # ensbl query
library("AnnotationDbi") # ensbl query
library("sctransform") # sc normalization,
library("SingleR")
library("velocyto.R")
library(Matrix)
library(stringr)
library(celldex)
library(scRNAseq)
library(CellSIUS)
######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ########
######## CREATION DE L'OBJECT SEURAT + DEMULTIPLEXAGE                                                                                  ########
######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ########
seurat_object <- function(patient){
##############################################
##### --        Préprocessing         -- #####
##############################################
PATH_DATA <- paste0("/home/boris/Documents/lipinskib/boris/Cellranger/result/",patient)
# matrice mRNA
rwa.mRNA <- Read10X(data.dir = paste0(PATH_DATA,"/mRNA/outs/filtered_feature_bc_matrix/")) # Chargement brute
#rwa.mRNA <- Read10X(data.dir = "/home/boris/Documents/lipinskib/flinovo/datas/datas_analysees/hFL_180008B/hFL_180008B_CellrangerCount/outs/filtered_feature_bc_matrix/")
cso <- CreateSeuratObject(counts = rwa.mRNA, project = patient, min.cells = 3, min.features = 200)          # objet seurat brute
umis <- GetAssayData(object = cso, slot = "counts")   # objet seurat umi
# matrice HTO
raw.hto <- Read10X(paste0(PATH_DATA,"/HTO/umi_count/"), gene.column = 1)
#raw.hto <- Read10X("/home/boris/Documents/lipinskib/flinovo/datas/datas_analysees/hFL_180008B/HTO/read_count/", gene.column = 1)
colnames(raw.hto) <- paste0(colnames(raw.hto),"-1")   # Ajoute -1 après le noms de chaque cellule HTO
hto <- raw.hto[c(1:4),]                               # Suppression des séquences unmapped (rownames(raw.hto)): on garde que les séquence mapped soit de 1 à 4
rownames(hto) <- c("pregreffe","subtilisin","collagenase","actinomycin_D") # Renommer les HTOs
joint.bcs <- intersect(colnames(umis),colnames(hto))  # D_On sélectionne les cellules qui ont un barcode commun entre HTO et mRNA
umis <- umis[, joint.bcs] # On garde que les lignes qui correspondent aux cellules en commun
hto <- as.matrix(hto[, joint.bcs])
# Normalisaiotn des 2 matrices = E_Mix: configuration de l'object seurat contenant les HTOs et mRNA
hashtag <- CreateSeuratObject(counts = umis, assay = "RNA", project = patient) # Configurer object seurat (mRNA)
hashtag <- NormalizeData(hashtag)                                                    # Normalisation des données mRNA
# On cherche les variables et on les met à l'échelle (scale)
hashtag <- FindVariableFeatures(hashtag, selection.method = "vst", nfeatures = 2000, verbose = FALSE)
hashtag <- ScaleData(hashtag,features = VariableFeatures(hashtag))
hashtag[["HTO"]] <- CreateAssayObject(counts = hto)                               # Ajoute les données HTO comme un nouvel assay indépendant du mRNA (retrouvé dans metadatas)
hashtag <- NormalizeData(hashtag, assay = "HTO",normalization.method = "CLR")     # Normalisation des données HTO (CLR transformation)
# F_Demultiplexing pour associer cellule à son échantillon d'origine
hashtag <- HTODemux(hashtag, assay = "HTO", positive.quantile = 0.99)
table(hashtag$HTO_classification.global)                # Visualisation du résultat de démultiplexing (visualisation singlet/doublet/neg: dans metadatas: HTO_classification.global)
# Clustering : Extraction des singlets
Idents(hashtag)<- 'HTO_classification.global'
singlet <- subset(hashtag, idents = "Singlet")
#############################################
##### -- identification des cellules -- #####
#############################################
hpca.se <- celldex::DatabaseImmuneCellExpressionData()
BD <- celldex::BlueprintEncodeData()
#### DB: DatabaseImmuneCellExpressionData() #####
results <- SingleR(test = as.SingleCellExperiment(singlet), ref = hpca.se, labels = hpca.se$label.main)
results.fine <- SingleR(test = as.SingleCellExperiment(singlet), ref = hpca.se, labels = hpca.se$label.fine)
singlet$SingleR.pruned.calls <- results$pruned.labels
singlet$SingleR.calls <- results$labels
singlet$SingleR.pruned.calls.fine <- results.fine$pruned.labels
singlet$SingleR.calls.fine <- results.fine$labels
#### DB: BlueprintEncodeData() #####
results.blueprint <- SingleR(test = as.SingleCellExperiment(singlet), ref = BD, labels = BD$label.main)
results.blueprint.fine <- SingleR(test = as.SingleCellExperiment(singlet), ref = BD, labels = BD$label.fine)
singlet$SingleR.pruned.calls.blueprint <- results$pruned.labels
singlet$SingleR.calls.blueprint <- results$labels
singlet$SingleR.pruned.calls.blueprint.fine <- results.blueprint.fine$pruned.labels
singlet$SingleR.calls.blueprint.fine <- results.blueprint.fine$labels
# Récap
#table(results$labels)
#table(results.fine$labels)
#############################################
##### --             VDJ             -- #####
#############################################
bcr <- read.csv("/home/boris/Documents/lipinskib/flinovo/datas/datas_analysees/hFL_130337/hFL_130337_CellrangerVDJ/outs/filtered_contig_annotations.csv")
# Remove the -1 at the end of each barcode: VERIFIER SI IL Y A LES TIRETS DANS OBJECT SINGLET!!!
#bcr$barcode <- gsub("-1", "", bcr$barcode)
bcr <- bcr[!duplicated(bcr$barcode), ]   # Subsets so only the first line of each barcode is kept,as each entry for given barcode will have same clonotype.
bcr <- bcr[,c("barcode", "raw_clonotype_id","chain","v_gene","d_gene","j_gene","c_gene","cdr3")]   # Only keep the barcode, clonotype columns, chain and vdj gene
names(bcr)[names(bcr) == "raw_clonotype_id"] <- "clonotype_id"
clonotype <- read.csv("/home/boris/Documents/lipinskib/flinovo/datas/datas_analysees/hFL_130337/hFL_130337_CellrangerVDJ/outs/clonotypes.csv")
bcr <- merge(bcr, clonotype[, c("clonotype_id", "cdr3s_aa")])   # Ajoute le cdr3s_aa du fichier clonotype à BCR (associé au bon clonotype): on garde que ceux pour lesquels on a une séquence cdr3
# Mettre les codes barres comme nom de la première colonne
bcr <- bcr[, c(2,1,3,4,5,6,7,8,9)]
rownames(bcr) <- bcr[,1]
bcr[,1] <- NULL
raw <- rbind(bcr[bcr$clonotype_id == 'clonotype1',],bcr[bcr$clonotype_id == 'clonotype2',],bcr[bcr$clonotype_id == 'clonotype3',],bcr[bcr$clonotype_id == 'clonotype4',])
singlet <- AddMetaData(object=singlet, metadata = raw)#, col.name = colnames(as.data.frame(bcr)))   # Add to the Seurat object's metadata.
return(singlet)
}
