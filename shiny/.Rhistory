######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ########
######## CREATION DE L'OBJECT SEURAT + DEMULTIPLEXAGE                                                                                  ########
######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ########
seurat_object <- function(patient){
##############################################
##### --        Préprocessing         -- #####
##############################################
PATH_DATA <- paste0("/home/boris/Documents/lipinskib/boris/Cellranger/result/",patient)
# matrice mRNA
#rwa.mRNA <- Read10X(data.dir = paste0(PATH_DATA,"/mRNA/",patient,"_CellrangerCount/outs/filtered_feature_bc_matrix/")) # Chargement brute
rwa.mRNA <- Read10X(data.dir = "/home/boris/Documents/lipinskib/flinovo/datas/datas_analysees/hFL_130337/chemistry_fiveprime/hFL_130337_CellrangerCount/outs/filtered_feature_bc_matrix")
cso <- CreateSeuratObject(counts = rwa.mRNA, project = patient, min.cells = 3, min.features = 200)          # objet seurat brute
umis <- GetAssayData(object = cso, slot = "counts")   # objet seurat umi
# matrice HTO
#raw.hto <- Read10X(paste0(PATH_DATA,"/HTO/umi_count/"), gene.column = 1)
raw.hto <- Read10X("/home/boris/Documents/lipinskib/flinovo/datas/datas_analysees/hFL_130337/HTO_HCL/read_count/", gene.column = 1)
colnames(raw.hto) <- paste0(colnames(raw.hto),"-1")   # Ajoute -1 après le noms de chaque cellule HTO
hto <- raw.hto[c(1:4),]                               # Suppression des séquences unmapped (rownames(raw.hto)): on garde que les séquence mapped soit de 1 à 4
rownames(hto) <- c("pregreffe","subtilisin","collagenase","actinomycin_D") # Renommer les HTOs
joint.bcs <- intersect(colnames(umis),colnames(hto))  # D_On sélectionne les cellules qui ont un barcode commun entre HTO et mRNA
umis <- umis[, joint.bcs] # On garde que les lignes qui correspondent aux cellules en commun
hto <- as.matrix(hto[, joint.bcs])
# Normalisaiotn des 2 matrices = E_Mix: configuration de l'object seurat contenant les HTOs et mRNA
hashtag <- CreateSeuratObject(counts = umis, assay = "RNA", project = patient) # Configurer object seurat (mRNA)
hashtag <- NormalizeData(hashtag)                                                    # Normalisation des données mRNA
# On cherche les variables et on les met à l'échelle (scale)
hashtag <- FindVariableFeatures(hashtag, selection.method = "vst", nfeatures = 2000, verbose = FALSE)
hashtag <- ScaleData(hashtag,features = VariableFeatures(hashtag))
hashtag[["HTO"]] <- CreateAssayObject(counts = hto)                               # Ajoute les données HTO comme un nouvel assay indépendant du mRNA (retrouvé dans metadatas)
hashtag <- NormalizeData(hashtag, assay = "HTO",normalization.method = "CLR")     # Normalisation des données HTO (CLR transformation)
# F_Demultiplexing pour associer cellule à son échantillon d'origine
hashtag <- HTODemux(hashtag, assay = "HTO", positive.quantile = 0.99)
table(hashtag$HTO_classification.global)                # Visualisation du résultat de démultiplexing (visualisation singlet/doublet/neg: dans metadatas: HTO_classification.global)
# Clustering : Extraction des singlets
Idents(hashtag)<- 'HTO_classification.global'
singlet <- subset(hashtag, idents = "Singlet")
#############################################
##### -- identification des cellules -- #####
#############################################
hpca.se <- celldex::DatabaseImmuneCellExpressionData()
BD <- celldex::BlueprintEncodeData()
#### DB: DatabaseImmuneCellExpressionData() #####
results <- SingleR(test = as.SingleCellExperiment(singlet), ref = hpca.se, labels = hpca.se$label.main)
results.fine <- SingleR(test = as.SingleCellExperiment(singlet), ref = hpca.se, labels = hpca.se$label.fine)
singlet$SingleR.pruned.calls <- results$pruned.labels
singlet$SingleR.calls <- results$labels
singlet$SingleR.pruned.calls.fine <- results.fine$pruned.labels
singlet$SingleR.calls.fine <- results.fine$labels
#### DB: BlueprintEncodeData() #####
results.blueprint <- SingleR(test = as.SingleCellExperiment(singlet), ref = BD, labels = BD$label.main)
results.blueprint.fine <- SingleR(test = as.SingleCellExperiment(singlet), ref = BD, labels = BD$label.fine)
singlet$SingleR.pruned.calls.blueprint <- results$pruned.labels
singlet$SingleR.calls.blueprint <- results$labels
singlet$SingleR.pruned.calls.blueprint.fine <- results.blueprint.fine$pruned.labels
singlet$SingleR.calls.blueprint.fine <- results.blueprint.fine$labels
# Récap
#table(results$labels)
#table(results.fine$labels)
#############################################
##### --             VDJ             -- #####
#############################################
bcr <- read.csv("/home/boris/Documents/lipinskib/flinovo/datas/datas_analysees/hFL_130337/hFL_130337_CellrangerVDJ/outs/filtered_contig_annotations.csv")
# Remove the -1 at the end of each barcode: VERIFIER SI IL Y A LES TIRETS DANS OBJECT SINGLET!!!
#bcr$barcode <- gsub("-1", "", bcr$barcode)
bcr <- bcr[!duplicated(bcr$barcode), ]   # Subsets so only the first line of each barcode is kept,as each entry for given barcode will have same clonotype.
bcr <- bcr[,c("barcode", "raw_clonotype_id","chain","v_gene","d_gene","j_gene","c_gene","cdr3")]   # Only keep the barcode, clonotype columns, chain and vdj gene
names(bcr)[names(bcr) == "raw_clonotype_id"] <- "clonotype_id"
clonotype <- read.csv("/home/boris/Documents/lipinskib/flinovo/datas/datas_analysees/hFL_130337/hFL_130337_CellrangerVDJ/outs/clonotypes.csv")
bcr <- merge(bcr, clonotype[, c("clonotype_id", "cdr3s_aa")])   # Ajoute le cdr3s_aa du fichier clonotype à BCR (associé au bon clonotype): on garde que ceux pour lesquels on a une séquence cdr3
# Mettre les codes barres comme nom de la première colonne
bcr <- bcr[, c(2,1,3,4,5,6,7,8,9)]
rownames(bcr) <- bcr[,1]
bcr[,1] <- NULL
raw <- rbind(bcr[bcr$clonotype_id == 'clonotype1',],bcr[bcr$clonotype_id == 'clonotype2',],bcr[bcr$clonotype_id == 'clonotype3',],bcr[bcr$clonotype_id == 'clonotype4',])
singlet <- AddMetaData(object=singlet, metadata = raw)#, col.name = colnames(as.data.frame(bcr)))   # Add to the Seurat object's metadata.
return(singlet)
}
#### Extraction des sous pop HTO : pregreffe / actinomycin RCHOP / actinomycin placébo
singlet <- seurat_object("hFL_130337")
######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ########
######## Visualisation                                                                                                                 ########
######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ######## ########
visualitation <- function(singlet){
######## ADD MITOCHONDRIAL ANALYSES ########
singlet[["percent.mt"]] <- PercentageFeatureSet(singlet, pattern = "^MT-") # On ajoute aux metadatas la colonne % reads mitochondrit
singlet <- subset(singlet, subset = nFeature_RNA > 200 & nFeature_RNA < 2500 & percent.mt < 5) # QC: Filtre cellules avec 200<nFeature>2500 + cellules avec moins de 5% gênes mit
######## ADD PCA TO SEURAT OBJECT ########
singlet <- FindVariableFeatures(singlet, selection.method = "mean.var.plot", nfeatures = 1000)  # Sélection des 1000 gênes les plus variables
singlet <- ScaleData(singlet, features = VariableFeatures(singlet))           # Mise à l'échelle des gênes variables
singlet <- RunPCA(singlet, features = VariableFeatures(singlet), ndims.print = 1:10, nfeatures.print = 30)  # PCA: les gênes les plus variables (positifs et negatifs) sur 5 PCs
singlet <- NormalizeData(singlet, normalization.method = "LogNormalize", scale.factor = 10000) # Normalisation des données: LogNormalize
#Identification of highly variable features (feature selection)
singlet <- FindVariableFeatures(singlet, selection.method = "vst", nfeatures = 2000) # Identification des 2000 gênes les plus variables (plus et moins) entre cellules: beaucoup exprimés dans certaines cellules et moins dans d'autres
singlet <- ScaleData(singlet, features = rownames(singlet)) # Mise à l'échelle des données pour PCA: Scale datas, données stockées dans singlet@assays$RNA@scale.data singlet[["RNA"]]@scale.data
singlet <- RunPCA(singlet, features = VariableFeatures(singlet), ndims.print = 1:10, nfeatures.print = 30) # PCA sur données précédentes
######## ADD UMAP TO SEURAT OBJECT ########
singlet <- FindNeighbors(singlet, reduction = "pca", dims = 1:40) # Clustering: Attention dims varie en fonction du nombre de PCs trouvées avant
singlet <- FindClusters(singlet, resolution = 0.5) #head(Idents(singlet), 10) # Visualisation des identifiants des 10 premières cellules
singlet <- RunUMAP(singlet, reduction = "pca", dims = 1:40) # UMAP, valeur dims fonction nombre PCs: singlet
######## ADD TSNE TO SEURAT OBJECT ########
singlet <- FindNeighbors(singlet, reduction = "pca", dims = 1:40) # tsne, valeur dims fonction nombre PCs
singlet <- FindClusters(singlet, resolution = 0.6, verbose = FALSE)
singlet <- RunTSNE(singlet, reduction = "pca", dims = 1:40)
######## Ohter PCA analysis ########
singlet <- JackStraw(singlet, num.replicate = 100)
singlet <- ScoreJackStraw(singlet, dims = 1:20)
return(singlet)
}
singlet <- visualitation(singlet)
######## Main visualisation ########
#Mitochondrie
VlnPlot(singlet, features = c("nFeature_RNA", "nCount_RNA", "percent.mt"), ncol = 3)
VlnPlot(singlet, features = c("nFeature_RNA", "nCount_RNA", "percent.mt"), ncol = 3, group.by = "HTO_classification")
plot1 <- FeatureScatter(singlet, feature1 = "nCount_RNA", feature2 = "percent.mt", group.by = "HTO_classification")
plot2 <- FeatureScatter(singlet, feature1 = "nCount_RNA", feature2 = "nFeature_RNA", group.by = "HTO_classification")
plot1 + plot2
#PCA
DimPlot(singlet, reduction = "pca")
print(singlet[["pca"]], dims = 1:10, nfeatures = 10)
ElbowPlot(singlet, ndims = 50, reduction = "pca")
#UMAP
DimPlot(singlet, reduction = "umap", label = TRUE) #UMAPPlot(object = singlet)
DimPlot(singlet, reduction = "umap", group.by = "SingleR.calls")
DimPlot(singlet, reduction = "umap", group.by = "SingleR.calls.fine")
DimPlot(singlet, reduction = "umap", group.by = "SingleR.calls.blueprint")
DimPlot(singlet, reduction = "umap", group.by = "SingleR.calls.blueprint.fine")
#TSNE
DimPlot(singlet, reduction = "tsne", label = TRUE) #TSNEPlot(object = singlet)
DimPlot(singlet, reduction = "tsne", group.by = "SingleR.calls")
DimPlot(singlet, reduction = "tsne", group.by = "SingleR.calls.fine")
DimPlot(singlet, reduction = "tsne", group.by = "SingleR.calls.blueprint")
DimPlot(singlet, reduction = "tsne", group.by = "SingleR.calls.blueprint.fine")
TSNEPlot(object = singlet, group.by = "clonotype_id", label.size = 0.0, pt.size = 1)
plots<-TSNEPlot(object = singlet, group.by = c("v_gene","HTO_maxID", "SingleR.calls.blueprint"), split.by = "clonotype_id", label.size = 0.0, pt.size = 1)
plots & theme(legend.position = "top") & guides(color = guide_legend(nrow = 2, byrow = TRUE, override.aes = list(size = 1)))
# Identify the 10 most highly variable genes
top10 <- head(VariableFeatures(singlet), 10)
VariableFeaturePlot(singlet)
LabelPoints(plot = VariableFeaturePlot(singlet), points = top10, repel = TRUE) # plot variable features with and without labels
